##############################################################################
# ProductivityHub — .env.example
# Copy this to .env and fill in every value marked with <CHANGE_ME>
# The setup script (./scripts/setup.sh) auto-generates most secrets for you.
##############################################################################

# ─── DOMAIN ──────────────────────────────────────────────────────────────────
# Your root domain. Services will be at <tool>.BASE_DOMAIN
BASE_DOMAIN=yourdomain.com

# Email for Let's Encrypt TLS certificates (required by ACME)
ACME_EMAIL=you@example.com

# ─── TIMEZONE ────────────────────────────────────────────────────────────────
TIMEZONE=UTC

# ─── DASHBOARD AUTH ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=<CHANGE_ME>
NEXTAUTH_SECRET=<run: openssl rand -base64 32>

# ─── CAL.DIY ─────────────────────────────────────────────────────────────────
CAL_DB_PASSWORD=<run: openssl rand -hex 16>
CAL_ENCRYPTION_KEY=<run: openssl rand -hex 32>

# ─── PLAUSIBLE ANALYTICS ─────────────────────────────────────────────────────
PLAUSIBLE_DB_PASSWORD=<run: openssl rand -hex 16>
PLAUSIBLE_SECRET_KEY=<run: openssl rand -hex 64>

# ─── GHOST ───────────────────────────────────────────────────────────────────
GHOST_DB_ROOT_PASSWORD=<run: openssl rand -hex 16>
GHOST_DB_PASSWORD=<run: openssl rand -hex 16>

# Optional SMTP for Ghost email sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── N8N ─────────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=<run: openssl rand -hex 32>

# ─── SUPABASE ────────────────────────────────────────────────────────────────
SUPABASE_DB_PASSWORD=<run: openssl rand -hex 16>
# Generate these with: node -e "require('crypto').randomBytes(64).toString('base64url')"
SUPABASE_ANON_KEY=<generate JWT>
SUPABASE_SERVICE_KEY=<generate JWT>

# ─── MEDUSA ──────────────────────────────────────────────────────────────────
MEDUSA_DB_PASSWORD=<run: openssl rand -hex 16>
MEDUSA_JWT_SECRET=<run: openssl rand -hex 32>
MEDUSA_COOKIE_SECRET=<run: openssl rand -hex 32>

# ─── APPFLOWY CLOUD ──────────────────────────────────────────────────────────
APPFLOWY_DB_PASSWORD=<run: openssl rand -hex 16>
APPFLOWY_MINIO_USER=minioadmin
APPFLOWY_MINIO_PASSWORD=<run: openssl rand -hex 16>
APPFLOWY_JWT_SECRET=<run: openssl rand -hex 32>

# ─── COOLIFY ─────────────────────────────────────────────────────────────────
COOLIFY_DB_PASSWORD=<run: openssl rand -hex 16>
COOLIFY_REDIS_PASSWORD=<run: openssl rand -hex 16>
COOLIFY_APP_KEY=<run: openssl rand -base64 32>

# ─── LISTMONK ────────────────────────────────────────────────────────────────
LISTMONK_DB_PASSWORD=<run: openssl rand -hex 16>

# ─── PENPOT ──────────────────────────────────────────────────────────────────
PENPOT_DB_PASSWORD=<run: openssl rand -hex 16>
PENPOT_SECRET_KEY=<run: openssl rand -hex 32>
